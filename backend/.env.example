# PostgreSQL Connection URL (Neon pooled/non-pooled string)
DATABASE_URL=postgresql://user:password@host-pooler.region.neon.tech/dbname?sslmode=require

# JWT Configuration settings
JWT_SECRET=generate_your_own_secure_random_string_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Google Gemini API key for Intelligent Scraper module
GEMINI_API_KEY=your_gemini_api_key_here
